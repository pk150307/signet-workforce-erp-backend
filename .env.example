# JWT
JWT_SECRET=2d2fcbec5b674f8dbb2b4b7d8d7f6b4b7d9d9d1c8a4e5f6a
JWT_ISSUER=SignetWorkforceERP
JWT_AUDIENCE=SignetWorkforceERPUsers
JWT_EXPIRY_HOURS=8
REFRESH_TOKEN_DAYS=7
REMEMBER_ME_DAYS=30
SESSION_IDLE_TIMEOUT_MINUTES=30

# Auth policy
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=30
PASSWORD_HISTORY_COUNT=5
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
PASSWORD_EXPIRY_DAYS=90

# Frontend (password reset links)
FRONTEND_URL=http://localhost:4200

# Email (optional — logs to console when disabled)
EMAIL_ENABLED=false
EMAIL_FROM=noreply@signetcorporateservices.com

# CORS
CORS_ORIGINS=https://erp.signetcorporateservices.com

# Uploads
UPLOAD_PATH=uploads
PUBLIC_BASE_URL=https://api.signetcorporateservices.com/uploads

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# S3 — private bucket; downloads use pre-signed URLs generated by the API (never make bucket public)
AWS_REGION=ap-south-1
AWS_BUCKET_NAME=your-bucket-name
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# IAM user/role must allow: s3:PutObject, s3:GetObject, s3:HeadBucket on the bucket
# Optional: set to public-read only if your bucket allows ACLs
# S3_OBJECT_ACL=public-read
