# Application
PORT=5000
NODE_ENV=production
LOG_LEVEL=info

# Database
DB_HOST=signet-workforce-db.cnkkq6k8a3gr.ap-south-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=workforce
