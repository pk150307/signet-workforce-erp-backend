# Application
PORT=5000
NODE_ENV=development
LOG_LEVEL=info

# Database
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=signet_workforce_erp
DB_USER=postgres
DB_PASSWORD=postgres

# JWT (use 32+ characters in production)
JWT_SECRET=SignetWorkforceERP-SuperSecretKey-ChangeInProduction-2024!@#
JWT_ISSUER=SignetWorkforceERP
JWT_AUDIENCE=SignetWorkforceERPUsers
JWT_EXPIRY_HOURS=8
REFRESH_TOKEN_DAYS=7

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:4200

# File storage (relative to backend/ when running locally)
UPLOAD_PATH=../uploads
PUBLIC_BASE_URL=http://localhost:5000/uploads

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
