{"error":"column dg.grade_code does not exist","level":"error","message":"Database query failed","query":"\n    SELECT e.employee_code, e.basic_salary, e.gross_salary, e.designation_grade_id,\n           ed.designation_grade_id AS ed_grade_id, ed.basic_salary AS ed_basic, ed.gross_salary AS ed_gross,\n           dg.grade_code, dg.basic_salary AS dg_basic, dg.house_rent_allowance AS dg_hra, dg.special_allowance AS dg_sa\n    FROM employees e\n    LEFT JOIN employee_employment_details ed ON ed.employee_id = e.id AND ed.is_current = TRUE\n    LEFT JOIN designation_grades dg ON dg.id = COALESCE(ed.designation_grade_id, e.designation_grade_id)\n    WHERE e.id = $1","service":"signet-workforce-erp","timestamp":"2026-06-21T07:57:09.487Z"}
