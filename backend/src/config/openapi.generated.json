    "/api/billing/invoices/generate-by-sites": {
      "post": {
        "tags": [
          "Billing"
        ],
        "summary": "Auto-generate invoices for active sites",
        "description": "Creates one invoice per site using headcount and site billing rates. Skips sites that already have an invoice for the period.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "allOf": [
                  {
                    "$ref": "#/components/schemas/MonthYearBody"
                  },
                  {
                    "type": "object",
                    "properties": {
                      "siteIds": {
                        "type": "array",
                        "items": {
                          "type": "string",
                          "format": "uuid"
                        }
                      },
                      "gstRate": {
                        "type": "number",
                        "default": 18
                      },
                      "dueDateDays": {
                        "type": "integer",
                        "default": 30
                      },
                      "notes": {
                        "type": "string"
                      }
                    }
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Generation summary",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "generated": {
                      "type": "integer"
                    },
                    "skipped": {
                      "type": "integer"
                    },
                    "invoices": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "siteId": {
                            "type": "string",
                            "format": "uuid"
                          },
                          "siteName": {
                            "type": "string"
                          },
                          "invoiceId": {
                            "type": "string",
                            "format": "uuid"
                          },
                          "invoiceNumber": {
                            "type": "string"
                          },
                          "totalAmount": {
                            "type": "number"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
